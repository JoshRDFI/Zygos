# Zygos environment template
# Copy to .env and replace values as needed:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Provider API keys
# -----------------------------------------------------------------------------
# OpenAI key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-openai-example-xxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-example-xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Runtime + diagnostics
# -----------------------------------------------------------------------------
# Set to 1 for verbose logs, 0 for normal logging.
ZYGOS_DEBUG=0

# -----------------------------------------------------------------------------
# SQLite persistence paths
# -----------------------------------------------------------------------------
# Conversation context DB (history, context compaction metadata, etc.)
ZYGOS_CONTEXT_DB=.zygos/context.db

# Learning system DB (proposals, evaluations, approvals/rollbacks)
ZYGOS_LEARNING_DB=.zygos/learning.db

# Interview workflow DB (sessions, turns, generated plans)
# If unset, Zygos reuses ZYGOS_CONTEXT_DB.
ZYGOS_INTERVIEW_DB=.zygos/context.db

# -----------------------------------------------------------------------------
# Optional notes
# -----------------------------------------------------------------------------
# - Provider endpoints/models are configured in YAML (config/default.yaml).
# - Ollama and vLLM usually do not require API keys unless your deployment adds auth.
# - For production, do not store real secrets in .env files committed to git.
