{
  "name": "zygos",
  "version": "0.1.0",
  "description": "Zygos (ζυγός: yoke/coupling) - multi-provider AI orchestration with RDT reasoning, tools, learning, and interview workflows",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "zygos": "dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/zygos.git"
  },
  "homepage": "https://github.com/your-org/zygos#readme",
  "bugs": {
    "url": "https://github.com/your-org/zygos/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "tsx scripts/verify-installation.ts",
    "test": "tsx --test test/**/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov npm run test"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "yaml": "^2.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "c8": "^10.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
